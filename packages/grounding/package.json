{
  "name": "@seldon/grounding",
  "version": "0.1.0",
  "description": "Web-grounding for Seldon: a Fetcher interface (Wikipedia REST implementation) and a persistent JSON+Markdown fact cache.",
  "keywords": [
    "llm",
    "grounding",
    "wikipedia",
    "cache"
  ],
  "license": "MIT",
  "author": "Richard Astbury",
  "homepage": "https://github.com/richorama/seldon#readme",
  "bugs": "https://github.com/richorama/seldon/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richorama/seldon.git",
    "directory": "packages/grounding"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build"
  }
}
