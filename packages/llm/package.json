{
  "name": "@seldon/llm",
  "version": "0.1.0",
  "description": "Thin LLM provider abstraction for Seldon. Azure OpenAI first, plus a deterministic mock provider for tests.",
  "keywords": [
    "llm",
    "azure-openai",
    "openai",
    "provider"
  ],
  "license": "MIT",
  "author": "Richard Astbury",
  "homepage": "https://github.com/richorama/seldon#readme",
  "bugs": "https://github.com/richorama/seldon/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richorama/seldon.git",
    "directory": "packages/llm"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "openai": "^4.77.0"
  }
}
