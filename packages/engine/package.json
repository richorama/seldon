{
  "name": "@seldon/engine",
  "version": "0.1.0",
  "description": "Seldon prediction engine: entity vagents deliberate over future events to produce a reasoned, time-stamped forecast.",
  "keywords": [
    "llm",
    "prediction",
    "forecasting",
    "psychohistory",
    "multi-agent",
    "simulation"
  ],
  "license": "MIT",
  "author": "Richard Astbury",
  "homepage": "https://github.com/richorama/seldon#readme",
  "bugs": "https://github.com/richorama/seldon/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richorama/seldon.git",
    "directory": "packages/engine"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@seldon/vagents": "0.1.0",
    "@seldon/llm": "0.1.0",
    "@seldon/grounding": "0.1.0",
    "zod": "^3.24.1"
  }
}
